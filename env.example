# Copy to .env and export or set in your IDE. For local development:
# MONGODB_URI=mongodb://admin:admin@localhost:27017/pigeonSkyRace?authSource=admin
# MONGODB_URI=mongodb://admin:admin@mongodb:27017/pigeonSkyRace?authSource=admin
# SERVER_PORT=8082
#
# JWT must be at least 32 UTF-8 bytes. Set a strong secret in production.
# JWT_SECRET=change-me-please-use-at-least-32-characters-long-secret
# JWT_EXPIRATION_MS=86400000
#
# CORS (comma-separated origins for the React app)
# CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
